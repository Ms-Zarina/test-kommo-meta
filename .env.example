# ── AI provider ─────────────────────────────────────────────────────────────
# Choose ONE backend. Selection order: AI_PROVIDER (explicit) → otherwise
# auto-detect (OPENROUTER_API_KEY present ⇒ openrouter, else anthropic).

# anthropic | openrouter   (optional — auto-detected from the key if omitted)
AI_PROVIDER=openrouter

# OpenRouter (key format: sk-or-v1-...)
# Default model is FREE (llama-3.3-70b:free). Free tier: 20 req/min, 50 req/day
# (<$10 lifetime credits) or 1000/day after a one-time $10 top-up. On the free
# tier the knowledge base is auto-trimmed (~13000 chars) to fit the prompt cap.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Direct Anthropic (only if AI_PROVIDER=anthropic). Not needed with OpenRouter.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Instagram (unchanged) ─────────────────────────────────────────────────────
IG_PAGE_ACCESS_TOKEN=
# IG_GRAPH_VERSION=v25.0

# ── Google Sheets dynamic pricing (public CSV export — unchanged) ─────────────
# Only the spreadsheet id is needed; share the sheet "Anyone with link → Viewer".
GOOGLE_SHEETS_ID=

# Other existing integrations (Kommo / Altegio / Meta verification) keep their
# current variables — this example only documents the AI + pricing layer.
